import hashlib
import datetime

def seal_asset(asset_name, content):
    timestamp = datetime.datetime.now().isoformat()
    # 創建資產唯一指紋
    signature = hashlib.sha256((asset_name + content + timestamp).encode()).hexdigest()
    
    seal_record = {
        "Asset": asset_name,
        "Owner": "CHANG WEI TSUNG",
        "Timestamp": timestamp,
        "Signature": signature
    }
    return seal_record

